PORT=3009
NODE_ENV=development

PRICING_SERVICE_NAME=pricingservice
PRICING_SERVICE_VERSION=1.0.0

JWT_SECRET=replace-with-real-secret
JWT_AUDIENCE=shipment-platform
JWT_ISSUER=shipment-auth

CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

DEFAULT_BASE_CURRENCY=USD
SUPPORTED_CURRENCIES=USD,EUR,INR,AED,GBP,JPY,SGD,CAD,AUD

EXCHANGE_RATE_PROVIDER=internal
EXCHANGE_RATE_REFRESH_SECONDS=900

DEFAULT_GST_RATE=0.18
DEFAULT_VAT_RATE=0.20
DEFAULT_INSURANCE_RATE=0.0125
DEFAULT_FUEL_SURCHARGE_RATE=0.08
DEFAULT_REMOTE_AREA_SURCHARGE=18
DEFAULT_HANDLING_FEE=12
DEFAULT_COMPLIANCE_FEE=15
DEFAULT_CUSTOMS_CLEARANCE_FEE=25
DEFAULT_PLATFORM_FEE_RATE=0.015
DEFAULT_MARGIN_RATE=0.14

MAX_WEIGHT_KG=100000
MAX_DIMENSION_CM=1000
MAX_DECLARED_VALUE=100000000